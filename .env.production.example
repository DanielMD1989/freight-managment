# ============================================================================
# FreightET — Production Environment Variables
#
# Copy this file: cp .env.production.example .env.local
# Fill in all values before deploying.
# ============================================================================

# --- Application ---
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_APP_URL=https://your-domain.com

# --- Database (AWS RDS PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
DATABASE_URL="postgresql://freight_admin:CHANGE_ME@freight-db.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com:5432/freight_db?schema=public"

# --- Authentication ---
# Generate with: openssl rand -base64 64
JWT_SECRET="CHANGE_ME_GENERATE_64_CHAR_SECRET"
JWT_ENCRYPTION_KEY="CHANGE_ME_GENERATE_32_CHAR_KEY"
MFA_TOKEN_SECRET="CHANGE_ME_GENERATE_32_CHAR_KEY"

# --- CSRF ---
# Auto-generated per session; no config needed

# --- Cron Jobs ---
# Generate with: openssl rand -hex 32
CRON_SECRET="CHANGE_ME_GENERATE_CRON_SECRET"

# --- AWS S3 (Document & POD Storage) ---
AWS_S3_BUCKET=freight-documents-prod
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# --- Email (Optional — logs to console if not set) ---
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=CHANGE_ME
# SMTP_PASS=CHANGE_ME
# EMAIL_FROM=noreply@your-domain.com

# --- SMS (Optional — Twilio or AfroMessage) ---
# AFROMESSAGE_API_KEY=CHANGE_ME
# AFROMESSAGE_SENDER_ID=FreightET

# --- Google Maps (Optional — for distance calculations) ---
# GOOGLE_MAPS_API_KEY=CHANGE_ME

# --- Redis (Optional — for caching, rate limiting) ---
# REDIS_URL=redis://freight-cache.xxxxxxxxxxxx.use1.cache.amazonaws.com:6379

# --- Sentry (Optional — error tracking) ---
# SENTRY_DSN=https://xxxx@sentry.io/xxxx

# --- Cloudinary (Optional — image optimization) ---
# CLOUDINARY_CLOUD_NAME=CHANGE_ME
# CLOUDINARY_API_KEY=CHANGE_ME
# CLOUDINARY_API_SECRET=CHANGE_ME

# --- CORS ---
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
